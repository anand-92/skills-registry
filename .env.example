# skills-mcp configuration — every variable is optional.
# Copy to `.env` and tweak, or set the variables directly in your MCP client config.

# One or more directories to scan for skills. Multiple paths are separated by
# the OS path separator (":" on macOS/Linux, ";" on Windows). Each entry must
# exist or the server fails fast at startup.
SKILLS_ROOT=~/my-skills

# Filename that marks a skill folder. Folders containing this file are exposed.
SKILLS_MAIN_FILE_NAME=SKILL.md

# Name advertised by the MCP server to connecting clients.
SKILLS_SERVER_NAME=skills

# Re-scan the skills directory on every request so edits take effect immediately.
# Useful during development; adds overhead, so leave off in production.
SKILLS_RELOAD=false

# Log verbosity for the server itself (CRITICAL | ERROR | WARNING | INFO | DEBUG).
SKILLS_LOG_LEVEL=INFO
